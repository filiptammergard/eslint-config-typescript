{
	"name": "@tammergard/eslint-config-typescript",
	"version": "6.0.0",
	"description": "A sharable ESLint config for TypeScript with personal preferences",
	"type": "module",
	"main": "index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		}
	},
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@10.33.2",
	"scripts": {
		"format": "prettier --write .",
		"format-check": "prettier --check .",
		"release": "pnpm changeset publish",
		"review": "pnpm install --frozen-lockfile && pnpm format-check"
	},
	"dependencies": {
		"@tammergard/eslint-config-base": "^6.0.0",
		"typescript-eslint": "^8.59.4"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@tammergard/prettier-config": "^3.0.0",
		"prettier": "^3.8.3"
	},
	"peerDependencies": {
		"eslint": ">=10.0.0",
		"prettier": ">=3.0.3",
		"typescript": ">=4.8.4 <6.1.0"
	},
	"files": [
		"index.js",
		"index.d.ts"
	],
	"keywords": [
		"eslint",
		"config",
		"eslint-config",
		"styleguide",
		"typescript",
		"flat-config",
		"eslint10"
	],
	"homepage": "https://github.com/filiptammergard/eslint-config-typescript#readme",
	"bugs": {
		"url": "https://github.com/filiptammergard/eslint-config-typescript/issues"
	},
	"license": "MIT",
	"author": {
		"name": "Filip Tammergård",
		"email": "filip+npm@tammergard.se",
		"url": "https://tammergard.se"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/filiptammergard/eslint-config-typescript.git"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
